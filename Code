def get_full_length_words(tfidf_vector, feature_names):
    # convert sparse tfidf_vector to dense
    dense_vector = tfidf_vector.toarray().flatten()

    # create a full-length word list
    words = [feature if value != 0 else "" for feature, value in zip(feature_names, dense_vector)]
    return words

